# =========================================================
# Huttons Asia Chatbot — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# =========================================================

# ── Supabase ──────────────────────────────────────────────
# Project URL from Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Anon key (safe to expose in browser) — from Settings > API
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Service role key (server-only, bypasses RLS) — keep secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── OpenAI ────────────────────────────────────────────────
# Used for gpt-4o (chat) and text-embedding-3-small (RAG)
OPENAI_API_KEY=sk-proj-...

# ── App URL ───────────────────────────────────────────────
# Public URL of this Next.js app (no trailing slash)
# Used for Google Calendar OAuth callbacks and deep links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Google Calendar (optional) ────────────────────────────
# OAuth credentials for per-org calendar integration.
# Create at console.cloud.google.com > APIs > Credentials
# Redirect URI: {NEXT_PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Telegram Admin Notifications (optional) ───────────────
# Per-org bot tokens are stored in the organisations table.
TELEGRAM_BOT_TOKEN=

# ── Stripe (optional — Phase 5) ───────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Twilio WhatsApp (optional — Phase 3) ─────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── Huttons Demo Org ID ───────────────────────────────────
# Set by migration 012_seed_huttons.sql
# Use this org_id when testing the chat API directly
HUTTONS_ORG_ID=55000000-0000-0000-0000-000000000001
