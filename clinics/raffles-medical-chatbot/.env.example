# Raffles Medical Chatbot — environment variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

OPENAI_API_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Clinics-specific notes:
# - NRIC collection: last 4 characters only (enforced in actions.ts at runtime)
# - Emergency protocol: "chest pain / cannot breathe" → redirect to 995, no booking
# - Demo org UUID: 11000000-0000-0000-0000-000000000001 (slug: raffles-medical)
# - Widget guard: __CLINIC_CHATBOT_LOADED | localStorage key: rmg_conversation_id
# - Bot name: Priya | Primary colour: #003087
